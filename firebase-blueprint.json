{
  "entities": {
    "QuizHistory": {
      "title": "Quiz History",
      "description": "A record of a generated quiz.",
      "type": "object",
      "properties": {
        "userId": {
          "type": "string",
          "description": "The ID of the user who generated the quiz."
        },
        "kelas": {
          "type": "string"
        },
        "semester": {
          "type": "string"
        },
        "materi": {
          "type": "string"
        },
        "jumlah": {
          "type": "number"
        },
        "jenisSoal": {
          "type": "string"
        },
        "level": {
          "type": "string"
        },
        "kurikulum": {
          "type": "string"
        },
        "content": {
          "type": "string",
          "description": "The generated markdown content of the quiz."
        },
        "createdAt": {
          "type": "string",
          "format": "timestamp",
          "description": "Server timestamp of when the quiz was generated."
        }
      },
      "required": ["userId", "kelas", "semester", "materi", "jumlah", "jenisSoal", "level", "kurikulum", "content", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}/quizHistory/{historyId}": {
      "schema": {
        "$ref": "#/entities/QuizHistory"
      },
      "description": "History of quizzes generated by the user."
    }
  }
}
